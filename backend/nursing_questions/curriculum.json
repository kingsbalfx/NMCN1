{
  "introduction": {
    "aim": "To prepare competent polyvalent nurse practitioners who: Use problem-solving skills, Provide safe, acceptable, effective, and affordable healthcare",
    "philosophy": "Nursing aims to achieve optimum health for individuals, families, and communities. Humans are bio-psycho-social beings. Nursing practice must be evidence-based. Health is a dynamic state of wellness. Healthcare accessibility and affordability are essential.",
    "objectives": [
      "Apply knowledge of biological, behavioural, and technological sciences",
      "Use the nursing process for comprehensive care",
      "Promote self-reliance in individuals and communities",
      "Work independently and collaboratively",
      "Supervise clinical experiences",
      "Provide family planning and primary health care",
      "Identify high-risk clients",
      "Provide safe healthcare environments",
      "Meet emotional and psychological needs"
    ],
    "competencies": [
      "Perform patient assessment (history, physical exam)",
      "Develop and implement care plans",
      "Interpret diagnostic results",
      "Evaluate outcomes of nursing care",
      "Maintain referral systems"
    ]
  },
